# Paddle Client-side Token (from Paddle Dashboard > Developer Tools > Authentication)
VITE_PADDLE_CLIENT_TOKEN=test_xxxxxxxxxxxxxxxxxxxx

# Paddle Environment: "sandbox" or "production"
VITE_PADDLE_ENVIRONMENT=sandbox

# Paddle Secret Key for server-side transaction verification (proxied via Vite dev server)
PADDLE_SECRET_KEY=pdl_sbox_xxxxxxxxxxxxxxxxxxxx

# Comma-separated Paddle Price IDs to display as products
# Create prices in: Paddle Dashboard > Catalog > Products > (add product) > Prices
VITE_PADDLE_PRICE_IDS=pri_xxxxxxxxxxxxxxxx,pri_yyyyyyyyyyyyyyyy,pri_zzzzzzzzzzzzzzzz
